# =====================================================================
# VDEMY - Environment Variables Template
# =====================================================================
# Hướng dẫn sử dụng:
#   1. Copy file này thành `.env`:        cp .env.example .env
#   2. Điền giá trị thật vào các biến bên dưới
#   3. File `.env` đã có trong .gitignore → KHÔNG bị commit lên Git
#
# Profiles:
#   - dev     : Chạy local (mặc định)
#   - staging : Chạy trên môi trường test / staging
#   - prod    : Chạy trên production / Docker
# =====================================================================

# ============================================
# APPLICATION
# ============================================
# Chọn 1 trong 3: dev | staging | prod
SPRING_PROFILES_ACTIVE=dev

# URL frontend (dùng cho CORS, redirect, email links)
FRONTEND_URL=http://localhost:3000
CONFIRM_USER_ENDPOINT=http://localhost:3000/login

# ============================================
# DATABASE (MySQL)
# ============================================
MYSQL_HOST=localhost
MYSQL_PORT=3307
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here

# ============================================
# REDIS
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379

# ============================================
# KAFKA
# ============================================
KAFKA_BOOTSTRAP_SERVERS=localhost:9094

# ============================================
# GOOGLE OAUTH2
# ============================================
# Lấy từ: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/authenticate

# ============================================
# JWT
# ============================================
# Issuer URI (Keycloak hoặc custom)
JWT_ISSUER_URI=http://localhost:8180/realms/QVinh

# Signing key - PHẢI >= 64 ký tự cho HS512!
# Tạo key mới: openssl rand -base64 64
JWT_SIGNER_KEY=your_jwt_signer_key_at_least_64_characters_long_generate_with_openssl_rand

# ============================================
# EMAIL (Gmail SMTP)
# ============================================
# Tạo App Password: https://myaccount.google.com/apppasswords
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password_here
MAIL_PORT=587

# ============================================
# CLOUDINARY (Media Upload)
# ============================================
# Lấy từ: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ============================================
# VNPAY (Payment Gateway)
# ============================================
# Lấy từ: https://sandbox.vnpayment.vn/
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_TMN_CODE=your_tmn_code
VNPAY_SECRET_KEY=your_vnpay_secret_key
VNPAY_RETURN_URL=http://localhost:3000/payment/vnpay-result
VNPAY_IPN_URL=http://localhost:8081/vinh/api/payment/vnpay/callback
